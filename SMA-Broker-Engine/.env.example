# ─── SMA Broker Engine — Environment Variables ───────────────────────────────
# Copy to .env (or export these before running), fill in real values.
# REQUIRED vars have no default — the service will refuse to start without them.

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Full JDBC URL, e.g. jdbc:postgresql://your-rds.amazonaws.com:5432/sma_broker
DB_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password

# ── Encryption (REQUIRED) ─────────────────────────────────────────────────────
# Must be at least 32 characters. Used for AES-256/GCM token encryption at rest.
ENCRYPTION_SECRET_KEY=change-me-to-a-32-plus-char-secret-key

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=9003

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Dev default (if unset): http://localhost:3000,http://localhost:5173
# Production: set to your deployed frontend URL.
CORS_ALLOWED_ORIGINS=https://yourapp.vercel.app

# ── Spring Profile ────────────────────────────────────────────────────────────
# Set to "prod" on EC2. Enables stricter logging, reduced actuator exposure.
SPRING_PROFILES_ACTIVE=prod

# ── Connection Pool (optional) ────────────────────────────────────────────────
DB_POOL_MAX=10
