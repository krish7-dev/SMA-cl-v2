# ─── SMA Data Engine — Environment Variables ─────────────────────────────────
# Copy to .env (or export these before running), fill in real values.
# REQUIRED vars have no default — the service will refuse to start without them.

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-supabase-db-password

# ── Inter-service URLs ────────────────────────────────────────────────────────
# On EC2: use private IP or internal DNS of Broker Engine instance.
BROKER_ENGINE_URL=http://127.0.0.1:9003

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=9005

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourapp.vercel.app

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Replay (optional) ────────────────────────────────────────────────────────
DATA_REPLAY_POOL_SIZE=4

# ── Connection Pool (optional) ────────────────────────────────────────────────
DB_POOL_MAX=10
